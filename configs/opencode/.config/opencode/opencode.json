    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--extension"],
      "enabled": false,
      "environment": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "DyfBXYMo3SK2ZVreuIp08aJFqMHUl1196yS6U2fBO_0"
      }
    },
    "mcp-atlassian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--env-file",
        "/Users/ice/mcp-atlassian.env",
        "ghcr.io/sooperset/mcp-atlassian:latest",
        "--verbose",
        "--no-jira-ssl-verify",
        "--no-confluence-ssl-verify"
      ],
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "digitalocean": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@digitalocean/mcp"],

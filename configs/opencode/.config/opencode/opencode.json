{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.7.5",
    "opencode-pty",
    "opencode-gemini-auth@latest"
  ],
  "lsp": {
    "scala-lsp": {
      "command": ["metals"],
      "extensions": [".scala", ".sc", ".sbt"]
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": "allow"
      }
    }
  },
  "mcp": {
    "dart": {
      "type": "local",
      "enabled": false,
      "command": ["dart", "mcp-server"]
    },
    "mcp-obsidian": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/projects/mcp-obsidian",
        "run",
        "mcp-obsidian"
      ],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      }
    },
    "PureSpectrum": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "apidog-mcp-server@latest", "--site-id=748984"]
    },
    "fd-forge-local": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "http://localhost:8080/mcp",
        "19876"
      ],
      "enabled": false,
      "timeout": 120000
    },
    "fd-forge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://forge.focaldata.com/mcp",
        "19876"
      ],
      "enabled": false
    },
    "fd-forge-dev": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://forge.focaldata.dev/mcp",
        "19876"
      ],
      "enabled": false
    },
    "kubefwd": {
      "type": "local",
      "command": ["kubefwd", "mcp"],
      "enabled": false
    },
    "notionMCP": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "focaldata": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/work/focaldata/fd-mcp",
        "run",
        "python",
        "-m",
        "src.server"
      ]
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--extension"],
      "enabled": false
    },
    "mcp-atlassian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--env-file",
        "/Users/ice/mcp-atlassian.env",
        "ghcr.io/sooperset/mcp-atlassian:latest",
        "--verbose",
        "--no-jira-ssl-verify",
        "--no-confluence-ssl-verify"
      ],
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "digitalocean": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "@digitalocean/mcp"],
      "environment": {
        "DIGITALOCEAN_API_TOKEN": "{env:DIGITALOCEAN_ACCESS_TOKEN}"
      }
    },
    "grafana": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_API_KEY",
        "mcp/grafana",
        "-t",
        "stdio",
        "--enabled-tools",
        "search,datasource,loki,searchlogs,prometheus"
      ],
      "environment": {
        "GRAFANA_URL": "http://host.docker.internal:3000",
        "GRAFANA_API_KEY": "{env:GRAFANA_API_KEY}"
      }
    },
    "grafana_dev": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "GRAFANA_URL",
        "-e",
        "GRAFANA_API_KEY",
        "mcp/grafana",
        "-t",
        "stdio",
        "--enabled-tools",
        "search,datasource,searchlogs,prometheus"
      ],
      "environment": {
        "GRAFANA_URL": "http://host.docker.internal:3000",
        "GRAFANA_API_KEY": "{env:GRAFANA_API_KEY_DEV}"
      }
    },
    "datadog": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
      "headers": {
        "DD_API_KEY": "{env:DD_API_KEY}",
        "DD_APPLICATION_KEY": "{env:DD_APP_KEY}"
      }
    },
    "tldr": {
      "type": "local",
      "enabled": false,
      "command": ["uvx", "--from", "llm-tldr", "tldr-mcp", "--project", "."]
    },
    "contextplus": {
      "type": "local",
      "enabled": false,
      "command": ["bunx", "contextplus"],
      "timeout": 60000,
      "environment": {
        "OLLAMA_HOST": "http://100.103.182.62:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "OLLAMA_CHAT_MODEL": "gemma3:4b"
      }
    },
    "takealot": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/projects/takealot",
        "run",
        "fastmcp",
        "run",
        "server.py:mcp"
      ]
    },
    "float": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/projects/mcp-float",
        "run",
        "fastmcp",
        "run",
        "server.py:mcp"
      ],
      "environment": {
        "FLOAT_EMAIL": "{env:FLOAT_EMAIL}",
        "FLOAT_PASSWORD": "{env:FLOAT_PASSWORD}"
      }
    },
    "onyx": {
      "type": "remote",
      "enabled": true,
      "url": "localhost:7002/mcp",
      "headers": {
        "Authorization": "Bearer on_8T1hjB5FKwlTTnHYIvLQa0VNaePxsVFKdVKIpDf2I4FVwz8Qlwk9bw8BqdqnKDOWkdQhTQwXrKJ-TvKjRDbenOeQd7sd4UBuf_pkLSCWKLabXRQRkLexD8xjFXXfceqbGAnKESyIoBfGClkL-IS1IDxLcBJB9lArN8ADUPRacB9HXHPoEhNB8v2J2yjyb3fmBx5lzkCOnVPDmubsGamLaNMTeVWvUjaRqOd5dxmdzJxBYgVHIl1luM_Nb6wW9lxO"
      }
    }
  },
  "provider": {
    "google": {
      "options": {
        "projectId": "opencode-dev-489617"
      }
    }
  }
}

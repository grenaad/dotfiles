    "focaldata": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/work/focaldata/fd-mcp",
        "run",
        "python",
        "-m",
        "src.server"

{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oc-auth-switcher@0.2.1",
    "opencode-pty",
    "opencode-gemini-auth@latest",
    "/Users/ice/projects/tron-agents/packages/orchid-agent/src/index.ts"
  ],
  "lsp": {},
  "agent": {},
  "mcp": {
    "dart": {
      "type": "local",
      "enabled": false,
      "command": ["dart", "mcp-server"]
    },
    "mcp-obsidian": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",
        "/Users/ice/projects/mcp-obsidian",
        "run",
        "mcp-obsidian"
      ],
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      }
    },
    "PureSpectrum": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "apidog-mcp-server@latest", "--site-id=748984"]
    },
    "fd-forge-local": {
      "type": "remote",
      "url": "http://localhost:8080/mcp"
    },
    "fd-forge": {
      "type": "remote",
      "url": "https://forge.focaldata.com/mcp"
    },
    "fd-forge-dev": {
      "type": "remote",
      "url": "https://forge.focaldata.dev/mcp"
    },
    "kubefwd": {
      "type": "local",
      "command": ["kubefwd", "mcp"],
      "enabled": false
    },
    "notionMCP": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "-y", "mcp-remote", "https://mcp.notion.com/mcp"]

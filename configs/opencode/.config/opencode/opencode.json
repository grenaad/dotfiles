        "DIGITALOCEAN_API_TOKEN": "{env:DIGITALOCEAN_ACCESS_TOKEN}"
      }
    },
    "datadog": {
      "type": "remote",
      "enabled": false,
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp",
      "headers": {
        "DD_API_KEY": "{env:DD_API_KEY}",
        "DD_APPLICATION_KEY": "{env:DD_APP_KEY}"
      }
    },
    "tldr": {
      "type": "local",
      "enabled": false,
      "command": ["uvx", "--from", "llm-tldr", "tldr-mcp", "--project", "."]
    },
    "mempalace": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-v",
        "mempalace-data:/data",
        "mempalace"
      ]
    },
    "takealot": {
      "type": "local",
      "enabled": false,
      "command": [
        "/Users/ice/.local/bin/uv",
        "--directory",

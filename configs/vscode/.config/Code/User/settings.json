{
  // Git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoredRepositories": [
    "/opt/homebrew/bin/flutter",
    "/opt/homebrew/Caskroom/flutter/2.8.1/flutter"
  ],
  // Vscode specific
  "telemetry.telemetryLevel": "off",
  "vim.sneak": true,
  "settingsSync.keybindingsPerPlatform": false,
  "git.mergeEditor": true,
  "terminal.integrated.shellIntegration.enabled": true,
  // Indentation
  "editor.detectIndentation": false,
  "editor.stickyTabStops": true,
  "editor.tabSize": 4,
  // Terminal
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "editor.fontFamily": "MesloLGS NF",
  // General
  "editor.bracketPairColorization.enabled": true,
  "json.maxItemsComputed": 10000,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/obj": true
  },
  // "terminal.integrated.inheritEnv": false,
  "files.associations": {
    "*.mqh": "cpp",
    "*.mq4": "cpp",
    "*.mq5": "cpp"
  },
  "search.exclude": {
    "**/obj": true
  },
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "zsh"
    },
    "bash": {
      "path": "bash"
    },
  },
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "zsh"
    },
    "bash": {
      "path": "bash",
      "icon": "terminal-bash"
    },
  },
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    }
  },
  "security.workspace.trust.untrustedFiles": "open",
  "editor.cursorStyle": "line",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "dart.lineLength": 150,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [
      150
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": false
  },
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "liveshare.audio.startCallOnShare": true,
  "dart.openDevTools": "flutter",
  "liveshare.audio.joinCallBehavior": "accept",
  "workbench.colorTheme": "Gruvbox Dark Hard",
  "cmake.configureOnOpen": false,

  // Plugin vscode-neovim
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
  "vscode-neovim.neovimInitVimPaths.darwin": "$HOME/.config/nvim/init.vim",

  // General editor
  "editor.lineNumbers": "relative",
  "editor.suggestSelection": "first",
}

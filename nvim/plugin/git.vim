nnoremap <A-g> :Gvdiffsplit!<CR>
nnoremap <leader>ga :Git fetch --all<CR>
nnoremap <leader>gc : GCheckout<CR>
nnoremap <leader>gs : Git<CR>			" Git status window
nnoremap <leader>gp : Git push<CR>		" Git push
nnoremap <leader>gf : diffget //2<CR>	" use the left diff
nnoremap <leader>gj : diffget //3<CR>   " use the right diff
